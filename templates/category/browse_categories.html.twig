{% extends 'layout.html.twig' %}

{% block title %}Categories - Our Store{% endblock %}

{% block content %}
    <div class="container my-5">
        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold">Shop by Category</h1>
            <p class="text-muted">Explore our wide range of products organized by category</p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for category in categories %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body text-center">
                            <h4 class="card-title">{{ category.nom }}</h4>
                            <p class="card-text text-muted">{{ category.description }}</p>
                            <a href="{{ path('app_products_by_category', {slug: category.slug}) }}" class="btn btn-outline-primary">
                                Browse {{ category.nom }}
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <p class="text-center text-muted">No categories found.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}