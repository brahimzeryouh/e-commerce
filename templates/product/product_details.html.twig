{% extends 'layout.html.twig' %}

{% block title %}{{ product.nom }} - Our Store{% endblock %}

{% block content %}
    <div class="container my-5">
        <div class="row">
            <!-- Product Image -->
            <div class="col-md-6">
                <img src="{{ asset('images/' ~ product.image) }}" class="img-fluid rounded" alt="{{ product.nom }}" onerror="this.src='https://via.placeholder.com/500x500'">
            </div>

            <!-- Product Information -->
            <div class="col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('app_products_by_category', {slug: product.category.slug}) }}">{{ product.category.nom }}</a></li>
                        <li class="breadcrumb-item active">{{ product.nom }}</li>
                    </ol>
                </nav>

                <span class="badge bg-primary mb-3">{{ product.category.nom }}</span>
                <h1 class="mb-3">{{ product.nom }}</h1>
                <h3 class="text-success mb-4">${{ product.prix|number_format(2) }}</h3>

                <div class="mb-4">
                    <h5>Description</h5>
                    <p class="text-muted">{{ product.description }}</p>
                </div>

                <!-- Add to Cart Form -->

                <form action="{{ path('app_cart_add', {id: product.id}) }}" method="get">
                    <div class="mb-3">
                        <label for="quantity" class="form-label">Quantity</label>
                        <input type="number" class="form-control" id="quantity" name="quantity" value="1" min="1" max="{{ product.stock }}" style="max-width: 100px;">
                    </div>
                    <div class="d-grid gap-2 d-md-flex">
                        <button type="submit" class="btn btn-primary btn-lg">Add to Cart</button>
                        <a href="{{ path('app_products') }}" class="btn btn-outline-secondary btn-lg">Continue Shopping</a>
                    </div>
                </form>

                <!-- Additional Info -->
                <div class="mt-4 pt-4 border-top">
                    <ul class="list-unstyled">
                        <li class="mb-2"><strong>Availability:</strong>
                            {% if product.stock > 0 %}
                                <span class="text-success">In Stock ({{ product.stock }} available)</span>
                            {% else %}
                                <span class="text-danger">Out of Stock</span>
                            {% endif %}
                        </li>
                        <li class="mb-2"><strong>Category:</strong> {{ product.category.nom }}</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}