{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<form method="post">
    <h1>Connexion</h1>

    {% if error %}
        <div class="alert alert-danger" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.8rem; border-radius: 8px; color: #fca5a5; font-size: 0.9rem; text-align: center; margin-bottom: 0.5rem;">
            {{ error.messageKey }}
        </div>
    {% endif %}

    <div>
        <label>Email</label>
        <input type="email" name="_username" value="{{ last_username }}" required>
    </div>
    <div>
        <label>Mot de passe</label>
        <input type="password" name="_password" required>
    </div>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
    <button type="submit">Se connecter</button>
</form>

<a href="{{ path('app_register') }}">Pas encore de compte ? S'inscrire</a>
{% endblock %}
