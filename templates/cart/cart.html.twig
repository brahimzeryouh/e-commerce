{% extends 'layout.html.twig' %}

{% block title %}Shopping Cart - Our Store{% endblock %}

{% block content %}
    <!-- Shopping Cart Section -->
    <div class="container my-5">
        <h1 class="mb-4">Shopping Cart</h1>

        {% if cart and cart.items|length > 0 %}
            <div class="row">
                <div class="col-lg-8">
                    <!-- Cart Items -->
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                    <tr>
                                        <th scope="col">Product</th>
                                        <th scope="col">Price</th>
                                        <th scope="col">Quantity</th>
                                        <th scope="col">Total</th>
                                        <th scope="col"></th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for item in cart.items %}
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <img src="{{ asset('images/thumbnail.png') }}" class="img-thumbnail me-3" alt="{{ item.product_name }}" style="width: 80px; height: 80px; object-fit: cover;">
                                                    <div>
                                                        <h6 class="mb-0">{{ item.product_name }}</h6>
                                                        <small class="text-muted">Product ID: #{{ item.product_id }}</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>${{ item.price|number_format(2) }}</td>
                                            <td>
                                                <form action="{{ path('app_cart_update', {id: item.product_id}) }}" method="post" class="d-flex gap-2">
                                                    <input type="number"
                                                           name="quantity"
                                                           value="{{ item.quantity }}"
                                                           min="1"
                                                           max="99"
                                                           class="form-control"
                                                           style="width: 70px;">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                                                </form>
                                            </td>
                                            <td class="fw-bold">${{ item.total|number_format(2) }}</td>
                                            <td>
                                                <a href="{{ path('app_cart_remove', {id: item.product_id}) }}"
                                                   class="btn btn-sm btn-outline-danger"
                                                   onclick="return confirm('Remove this item from cart?')">
                                                    Remove
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <a href="{{ path('app_products') }}" class="btn btn-outline-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                        </svg>
                        Continue Shopping
                    </a>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">Order Summary</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal:</span>
                                <span>${{ cart.total|number_format(2) }}</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Shipping:</span>
                                <span>
                                    {% if cart.total >= 100 %}
                                        Free
                                    {% else %}
                                        $10.00
                                    {% endif %}
                                </span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tax (20%):</span>
                                <span>${{ (cart.total * 0.20)|number_format(2) }}</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between mb-3">
                                <strong>Total:</strong>
                                <strong class="text-success">
                                    {% if cart.total >= 100 %}
                                        ${{ (cart.total * 1.20)|number_format(2) }}
                                    {% else %}
                                        ${{ ((cart.total + 10) * 1.20)|number_format(2) }}
                                    {% endif %}
                                </strong>
                            </div>
                            <div class="d-grid gap-2">
                                <a href="{{ path('app_cart_checkout') }}" class="btn btn-success btn-lg">Proceed to Checkout</a>
                                <a href="{{ path('app_cart_clear') }}"
                                   class="btn btn-outline-danger"
                                   onclick="return confirm('Clear entire cart?')">
                                    Clear Cart
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Promo Code -->
                    <div class="card mt-3">
                        <div class="card-body">
                            <h6 class="card-title">Have a promo code?</h6>
                            <form action="{{ path('app_cart_apply_promo') }}" method="post">
                                <div class="input-group">
                                    <input type="text" name="promo_code" class="form-control" placeholder="Enter code">
                                    <button class="btn btn-outline-secondary" type="submit">Apply</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <!-- Empty Cart -->
            <div class="text-center py-5">
                <div class="mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-cart-x text-muted" viewBox="0 0 16 16">
                        <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l.84 4.479 9.144-.459L13.89 4H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                    </svg>
                </div>
                <h3>Your cart is empty</h3>
                <p class="text-muted mb-4">Discover our products and add them to your cart.</p>
                <a href="{{ path('app_products') }}" class="btn btn-primary btn-lg">Shop Now</a>
            </div>
        {% endif %}
    </div>
{% endblock %}